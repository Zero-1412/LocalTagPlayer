        "required_skills": ["ltp-tag-manager-batch-tagging"],
        "forbidden_skills": ["ltp-apple-ui-design"],
        "status": "completed",
        "changed_files": []
      }
    },
    {
      "id": "reg-small-fix-scope",
      "category": "efficiency",
      "prompt": "修复已明确行号的单文件拼写问题，只输出允许与禁止读取的范围，不修改文件。",
