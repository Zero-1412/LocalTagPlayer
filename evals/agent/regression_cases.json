      "trials": 5,
      "expected": {
        "task_level": "2",
        "required_skills": ["ltp-cache-diagnostics"],
        "forbidden_skills": ["ltp-apple-ui-design"],
        "status": "completed",
        "changed_files": []
      }
    },
    {
