{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local Tag Player Agent Eval Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "task_level",
    "selected_skills",
    "task_contract",
    "validation_mode",
    "summary",
    "changed_files",
    "validation",
    "promotion_decision",
    "safety"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "failed"]
    },
    "task_level": {
      "type": "string",
      "enum": ["1", "2", "3", "none"]
    },
    "selected_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "task_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "scope", "non_goals", "done_when", "deliverable"],
      "properties": {
        "goal": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "non_goals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "done_when": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "assertion", "required"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "assertion": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" }
            }
          }
        },
        "deliverable": { "type": "string", "minLength": 1 }
      }
    },
    "validation_mode": {
      "type": "string",
      "enum": ["single_agent", "structured", "independent"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirement_id", "status", "method", "evidence"],
        "properties": {
          "requirement_id": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "blocked", "not_run"]
          },
          "method": {
            "type": "string",
            "enum": ["deterministic", "same_agent", "independent", "human"]
          },
          "evidence": { "type": "string" }
        }
      }
    },
    "promotion_decision": {
      "type": "string",
      "enum": ["promoted", "not_promoted", "needs_manual_qa"]
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "filter_query", "filtered_queue", "cache_queue", "user_data"],
      "properties": {
        "schema": { "type": "string" },
        "filter_query": { "type": "string" },
        "filtered_queue": { "type": "string" },
        "cache_queue": { "type": "string" },
        "user_data": { "type": "string" }
      }
    }
  }
}
